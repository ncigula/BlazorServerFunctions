@page "/demos/crud/server"
@rendermode InteractiveServer

@inject ICrudService CrudService

<PageTitle>CRUD — Server</PageTitle>

<div class="demo-header">
    <span class="badge bg-primary">🖥 Interactive Server</span>
    <span class="badge bg-secondary ms-2">ICrudService → CrudService (direct, no HTTP)</span>
</div>

<h2 class="mt-3">CRUD Service</h2>
<p>All verbs (GET / POST / PUT / PATCH / DELETE) called directly from server DI — no HTTP leaves the server.</p>

<div class="row g-3">

    @* GET *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header"><span class="badge bg-primary">GET</span> by ID</div>
            <div class="card-body">
                <div class="input-group mb-2">
                    <input class="form-control" type="number" @bind="_getId" />
                    <button class="btn btn-outline-primary" @onclick="CallGetAsync">Fetch</button>
                </div>
                @if (_getResult is not null)
                {
                    <div class="alert alert-primary py-1 mb-0"><small>@_getResult.Id | @_getResult.Name | @_getResult.Price.ToString("C")</small></div>
                }
            </div>
        </div>
    </div>

    @* POST *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header"><span class="badge bg-success">POST</span> Create</div>
            <div class="card-body">
                <input class="form-control mb-2" @bind="_createInput.Name" placeholder="Name" />
                <input class="form-control mb-2" type="number" step="0.01" @bind="_createInput.Price" placeholder="Price" />
                <button class="btn btn-outline-success" @onclick="CallCreateAsync">Create</button>
                @if (_createResult is not null)
                {
                    <div class="alert alert-success py-1 mt-2 mb-0"><small>@_createResult.Id | @_createResult.Name | @_createResult.Price.ToString("C")</small></div>
                }
            </div>
        </div>
    </div>

    @* PUT *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header"><span class="badge bg-warning text-dark">PUT</span> Update</div>
            <div class="card-body">
                <input class="form-control mb-2" type="number" @bind="_updateId" placeholder="ID" />
                <input class="form-control mb-2" @bind="_updateInput.Name" placeholder="Name" />
                <input class="form-control mb-2" type="number" step="0.01" @bind="_updateInput.Price" placeholder="Price" />
                <button class="btn btn-outline-warning" @onclick="CallUpdateAsync">Update</button>
                @if (_updateResult is not null)
                {
                    <div class="alert alert-warning py-1 mt-2 mb-0"><small>@_updateResult.Id | @_updateResult.Name | @_updateResult.Price.ToString("C")</small></div>
                }
            </div>
        </div>
    </div>

    @* PATCH *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header"><span class="badge bg-secondary">PATCH</span> Partial Update</div>
            <div class="card-body">
                <input class="form-control mb-2" type="number" @bind="_patchId" placeholder="ID" />
                <input class="form-control mb-2" @bind="_patchField" placeholder="Field (e.g. Name)" />
                <input class="form-control mb-2" @bind="_patchValue" placeholder="Value" />
                <button class="btn btn-outline-secondary" @onclick="CallPatchAsync">Patch</button>
                @if (_patchResult is not null)
                {
                    <div class="alert alert-secondary py-1 mt-2 mb-0"><small>@_patchResult.Id | @_patchResult.Name</small></div>
                }
            </div>
        </div>
    </div>

    @* DELETE *@
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header"><span class="badge bg-danger">DELETE</span></div>
            <div class="card-body">
                <div class="input-group mb-2">
                    <input class="form-control" type="number" @bind="_deleteId" />
                    <button class="btn btn-outline-danger" @onclick="CallDeleteAsync">Delete</button>
                </div>
                @if (_deleteMessage is not null)
                {
                    <div class="alert alert-success mb-0 py-1">@_deleteMessage</div>
                }
            </div>
        </div>
    </div>

</div>

@code {
    private int _getId = 1;
    private ComplexDto? _getResult;

    private readonly ComplexDto _createInput = new() { Name = "New Item", Price = 9.99m };
    private ComplexDto? _createResult;

    private int _updateId = 1;
    private readonly ComplexDto _updateInput = new() { Name = "Updated Item", Price = 19.99m };
    private ComplexDto? _updateResult;

    private int _patchId = 1;
    private string _patchField = "Name";
    private string _patchValue = "Patched Value";
    private ComplexDto? _patchResult;

    private int _deleteId = 1;
    private string? _deleteMessage;

    private async Task CallGetAsync() => _getResult = await CrudService.GetAsync(_getId);
    private async Task CallCreateAsync() => _createResult = await CrudService.CreateAsync(_createInput);
    private async Task CallUpdateAsync() => _updateResult = await CrudService.UpdateAsync(_updateId, _updateInput);
    private async Task CallPatchAsync() => _patchResult = await CrudService.PatchAsync(_patchId, _patchField, _patchValue);

    private async Task CallDeleteAsync()
    {
        await CrudService.DeleteAsync(_deleteId);
        _deleteMessage = $"Deleted item {_deleteId} ✓";
    }
}
