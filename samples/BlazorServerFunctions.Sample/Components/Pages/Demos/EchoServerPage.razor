@page "/demos/echo/server"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject IEchoService EchoService

<PageTitle>Echo — Server</PageTitle>

<div class="demo-header">
    <span class="badge bg-primary">🖥 Interactive Server</span>
    <span class="badge bg-secondary ms-2">IEchoService → EchoService (direct, no HTTP)</span>
</div>

<h2 class="mt-3">Echo Service</h2>
<p>Calls made directly from server DI — no HTTP request is sent.</p>

<div class="mb-3">
    <label class="form-label">Message</label>
    <input class="form-control" @bind="_message" placeholder="Type something..." />
</div>

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-outline-primary" @onclick="CallGetAsync">GET Echo</button>
    <button class="btn btn-outline-success" @onclick="CallPostAsync">POST Echo</button>
</div>

@if (_getResult is not null)
{
    <div class="alert alert-primary">
        <strong>GET result:</strong> <code>@_getResult</code>
    </div>
}
@if (_postResult is not null)
{
    <div class="alert alert-success">
        <strong>POST result:</strong> <code>@_postResult</code>
    </div>
}

@code {
    private string _message = "hello";
    private string? _getResult;
    private string? _postResult;

    private async Task CallGetAsync() =>
        _getResult = await EchoService.GetEchoAsync(_message);

    private async Task CallPostAsync() =>
        _postResult = await EchoService.PostEchoAsync(_message);
}
