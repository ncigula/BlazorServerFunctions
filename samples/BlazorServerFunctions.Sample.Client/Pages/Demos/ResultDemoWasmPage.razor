@page "/demos/result-mapper/wasm"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IResultDemoService ResultDemoService

<PageTitle>Result Mapper — WASM</PageTitle>

<div class="demo-header">
    <span class="badge bg-warning text-dark">🌐 WebAssembly</span>
    <span class="badge bg-secondary ms-2">IResultDemoService → ResultDemoServiceClient (HTTP)</span>
</div>

<h2 class="mt-3">Result Mapper Demo</h2>
<p>
    Same <code>IResultDemoService</code> interface, but this page runs in WebAssembly and calls the
    server over HTTP via the generated <code>ResultDemoServiceClient</code> proxy.
    The proxy deserialises a 200 OK response into <code>Result.Ok(value)</code> and a
    4xx/5xx ProblemDetails response into a failure <code>Result</code> — the caller never
    touches <code>HttpClient</code> directly.
</p>

@* ── Product table ── *@
<div class="d-flex align-items-center gap-2 mb-2">
    <h5 class="mb-0">Products</h5>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">↺ Refresh</button>
</div>

@if (_loading)
{
    <p><em>Loading…</em></p>
}
else if (_products.Length == 0)
{
    <p class="text-muted">No products found.</p>
}
else
{
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr><th>ID</th><th>Name</th><th>Price</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var p in _products)
            {
                <tr>
                    <td><code>@p.Id</code></td>
                    <td>@p.Name</td>
                    <td>@p.Price.ToString("C")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(p.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@* ── Lookup by ID (demonstrates 404) ── *@
<div class="card mb-3" style="max-width:380px">
    <div class="card-header"><span class="badge bg-info text-dark">GET</span><span class="ms-2">Lookup product by ID</span></div>
    <div class="card-body">
        <input class="form-control mb-2" type="number" @bind="_lookupId" placeholder="Product ID" />
        <button class="btn btn-info" @onclick="LookupAsync">Get</button>
        @if (_lookupResult is not null)
        {
            <div class="mt-2 @(_lookupResult.IsSuccess ? "alert alert-success" : "alert alert-danger") py-1">
                @if (_lookupResult.IsSuccess)
                { <span>✓ Found: @_lookupResult.Value!.Name (@_lookupResult.Value.Price.ToString("C"))</span> }
                else
                { <span>✗ [@_lookupResult.ErrorCode] @_lookupResult.ErrorMessage</span> }
            </div>
        }
    </div>
</div>

@* ── Create (demonstrates 409 conflict) ── *@
<div class="card mb-3" style="max-width:380px">
    <div class="card-header"><span class="badge bg-success">POST</span><span class="ms-2">Create product</span></div>
    <div class="card-body">
        <input class="form-control mb-2" @bind="_createName" placeholder="Name" />
        <input class="form-control mb-2" type="number" step="0.01" @bind="_createPrice" placeholder="Price" />
        <button class="btn btn-success" @onclick="CreateAsync">Create</button>
        @if (_createResult is not null)
        {
            <div class="mt-2 @(_createResult.IsSuccess ? "alert alert-success" : "alert alert-warning") py-1">
                @if (_createResult.IsSuccess)
                { <span>✓ Created: @_createResult.Value!.Name (#@_createResult.Value.Id)</span> }
                else
                { <span>✗ [@_createResult.ErrorCode] @_createResult.ErrorMessage</span> }
            </div>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private ProductDto[] _products = [];

    private int _lookupId = 99;
    private Result<ProductDto>? _lookupResult;

    private string _createName = "";
    private decimal _createPrice = 9.99m;
    private Result<ProductDto>? _createResult;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;

        // Probe first 10 IDs — success results form the table
        var tasks = Enumerable.Range(1, 10).Select(id => ResultDemoService.GetProductAsync(id));
        var results = await Task.WhenAll(tasks);
        _products = results.Where(r => r.IsSuccess).Select(r => r.Value!).ToArray();

        _loading = false;
    }

    private async Task LookupAsync()
    {
        _lookupResult = await ResultDemoService.GetProductAsync(_lookupId);
    }

    private async Task CreateAsync()
    {
        _createResult = await ResultDemoService.CreateProductAsync(_createName, _createPrice);
        if (_createResult.IsSuccess)
        {
            _createName = "";
            _createPrice = 9.99m;
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(int id)
    {
        var result = await ResultDemoService.DeleteProductAsync(id);
        if (result.IsSuccess)
            await LoadAsync();
    }
}
