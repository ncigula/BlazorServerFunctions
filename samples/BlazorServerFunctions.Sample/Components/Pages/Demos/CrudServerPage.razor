@page "/demos/crud/server"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject ICrudService CrudService

<PageTitle>CRUD — Server</PageTitle>

<div class="demo-header">
    <span class="badge bg-primary">🖥 Interactive Server</span>
    <span class="badge bg-secondary ms-2">ICrudService → CrudService (direct, no HTTP)</span>
</div>

<h2 class="mt-3">CRUD Service</h2>
<p>Operations call <code>CrudService</code> directly via server DI. The collection is shared in-memory (singleton) so changes persist across requests and are immediately visible on the WASM page too.</p>

@* ── Item list ── *@
<div class="d-flex align-items-center gap-2 mb-2">
    <h5 class="mb-0">Items</h5>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">↺ Refresh</button>
</div>

@if (_items is null)
{
    <p><em>Loading…</em></p>
}
else if (_items.Length == 0)
{
    <p class="text-muted">No items yet.</p>
}
else
{
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr><th>ID</th><th>Name</th><th>Description</th><th>Price</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td><code>@item.Id</code></td>
                    <td>@item.Name</td>
                    <td class="text-muted small">@item.Description</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => StartEdit(item)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_statusMessage is not null)
{
    <div class="alert alert-success py-1 mb-3">@_statusMessage</div>
}

@* ── Create / Edit form ── *@
<div class="card mb-3" style="max-width:420px">
    <div class="card-header">
        @if (_editId is null) { <span class="badge bg-success">POST</span><span class="ms-2">Create new item</span> }
        else { <span class="badge bg-warning text-dark">PUT</span><span class="ms-2">Editing item #@_editId</span> }
    </div>
    <div class="card-body">
        <input class="form-control mb-2" @bind="_formName" placeholder="Name" />
        <input class="form-control mb-2" @bind="_formDescription" placeholder="Description (optional)" />
        <input class="form-control mb-2" type="number" step="0.01" @bind="_formPrice" placeholder="Price" />
        <div class="d-flex gap-2">
            @if (_editId is null)
            {
                <button class="btn btn-success" @onclick="CreateAsync">Create</button>
            }
            else
            {
                <button class="btn btn-warning" @onclick="UpdateAsync">Save</button>
                <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
            }
        </div>
    </div>
</div>

@code {
    private ComplexDto[]? _items;
    private string? _statusMessage;

    private string _formName = "";
    private string _formDescription = "";
    private decimal _formPrice;
    private int? _editId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _items = await CrudService.GetAllAsync();
        _statusMessage = null;
    }

    private async Task CreateAsync()
    {
        var created = await CrudService.CreateAsync(new ComplexDto
        {
            Name = _formName,
            Description = _formDescription,
            Price = _formPrice,
        });
        _statusMessage = $"Created item #{created.Id} ✓";
        _formName = "";
        _formDescription = "";
        _formPrice = 0;
        await LoadAsync();
    }

    private void StartEdit(ComplexDto item)
    {
        _editId = item.Id;
        _formName = item.Name;
        _formDescription = item.Description ?? "";
        _formPrice = item.Price;
        _statusMessage = null;
    }

    private async Task UpdateAsync()
    {
        if (_editId is null) return;
        await CrudService.UpdateAsync(_editId.Value, new ComplexDto
        {
            Name = _formName,
            Description = _formDescription,
            Price = _formPrice,
        });
        _statusMessage = $"Updated item #{_editId} ✓";
        CancelEdit();
        await LoadAsync();
    }

    private void CancelEdit()
    {
        _editId = null;
        _formName = "";
        _formDescription = "";
        _formPrice = 0;
    }

    private async Task DeleteAsync(int id)
    {
        await CrudService.DeleteAsync(id);
        _statusMessage = $"Deleted item #{id} ✓";
        await LoadAsync();
    }
}
