@page "/demos/streaming/wasm"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@implements IDisposable

@inject IStreamingService StreamingService

<PageTitle>Streaming — WASM</PageTitle>

<div class="demo-header">
    <span class="badge bg-success">🌐 Interactive WebAssembly</span>
    <span class="badge bg-secondary ms-2">IStreamingService → StreamingServiceClient → chunked HTTP</span>
</div>

<h2 class="mt-3">Live Item Streaming</h2>
<p>
    Items arrive via the generated <code>StreamingServiceClient</code> HTTP proxy running in
    WebAssembly. The server endpoint returns an <code>IAsyncEnumerable&lt;StreamItemDto&gt;</code>
    which ASP.NET Core serialises as a chunked JSON stream; the client reads it with
    <code>ReadFromJsonAsAsyncEnumerable</code> and <code>HttpCompletionOption.ResponseHeadersRead</code>.
</p>

<div class="row g-2 align-items-center mb-3">
    <div class="col-auto">
        <label class="col-form-label">Items to stream</label>
    </div>
    <div class="col-auto">
        <input type="number" class="form-control" style="width:90px"
               @bind="_count" min="1" max="100" disabled="@_running" />
    </div>
    <div class="col-auto">
        <button class="btn btn-success" @onclick="StartAsync" disabled="@_running">▶ Start</button>
    </div>
    <div class="col-auto">
        <button class="btn btn-danger" @onclick="Cancel" disabled="@(!_running)">⏹ Cancel</button>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" @onclick="Reset" disabled="@_running">↺ Reset</button>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_items.Count > 0 || _running)
{
    <div class="mb-2 d-flex gap-2 align-items-center">
        <span class="badge bg-info text-dark">@_items.Count / @_count received</span>
        @if (_running)
        {
            <span class="badge bg-warning text-dark">⏳ Streaming…</span>
        }
        else if (_cancelled)
        {
            <span class="badge bg-danger">⏹ Cancelled after @_items.Count items</span>
        }
        else
        {
            <span class="badge bg-success">✓ Done</span>
        }
    </div>

    <table class="table table-sm table-striped" style="max-width:520px">
        <thead>
            <tr>
                <th style="width:50px">#</th>
                <th>Message</th>
                <th>Arrived at</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>@item.Index</td>
                    <td>@item.Message</td>
                    <td>@item.Timestamp.ToString("HH:mm:ss.fff")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private readonly List<StreamItemDto> _items = [];
    private CancellationTokenSource? _cts;
    private bool _running;
    private bool _cancelled;
    private string? _error;
    private int _count = 20;

    private async Task StartAsync()
    {
        _items.Clear();
        _cancelled = false;
        _error = null;
        _running = true;
        _cts = new CancellationTokenSource();

        try
        {
            await foreach (var item in StreamingService.StreamItemsAsync(_count, _cts.Token))
            {
                _items.Add(item);
                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
            _cancelled = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private void Cancel() => _cts?.Cancel();

    private void Reset()
    {
        _items.Clear();
        _cancelled = false;
        _error = null;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
